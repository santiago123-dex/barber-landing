---
import MainLayout from '../layouts/MainLayout.astro';
import { siteData } from '../data/site';

const { brand, navigation, hero, usp, services, gallery, testimonials, closingCta, contact, socialLinks, seo } = siteData;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Barbershop',
  name: brand.name,
  description: seo.description,
  image: hero.backgroundImage,
  telephone: contact.phoneValue,
  email: contact.emailValue,
  areaServed: brand.city,
  address: {
    '@type': 'PostalAddress',
    addressLocality: brand.city,
    addressCountry: 'CO',
  },
  sameAs: socialLinks.map((link) => link.href),
};
---

<MainLayout title={seo.title} description={seo.description} ogImage={seo.ogImage} jsonLd={schema}>
  <header
    data-site-header
    data-scrolled="false"
    class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300"
  >
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-5 py-4 md:px-8">
      <a href="#inicio" class="flex items-center gap-3 text-[0.7rem] uppercase tracking-[0.35em] text-ivory/75">
        <span class="font-display text-3xl font-semibold normal-case tracking-[0.08em] text-ivory">
          {brand.name}
        </span>
        <span class="hidden h-px w-10 bg-accent/60 md:block"></span>
        <span class="hidden md:inline">{brand.tagline}</span>
      </a>

      <nav class="hidden items-center gap-8 text-sm text-ivory/72 lg:flex">
        {
          navigation.map((item) => (
            <a class="transition hover:text-ivory" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden items-center gap-4 lg:flex">
        <a
          href={hero.primaryCtaHref}
          target="_blank"
          rel="noreferrer"
          class="rounded-full border border-accent/60 bg-accent px-5 py-3 text-sm font-semibold text-noir transition hover:-translate-y-0.5 hover:bg-white"
        >
          {hero.primaryCtaLabel}
        </a>
      </div>

      <button
        data-menu-toggle
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex size-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-ivory lg:hidden"
      >
        <span class="sr-only">Abrir menú</span>
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" data-mobile-menu class="hidden border-t border-white/10 bg-noir/95 px-5 py-5 backdrop-blur lg:hidden">
      <nav class="flex flex-col gap-4 text-sm text-ivory/82">
        {
          navigation.map((item) => (
            <a class="transition hover:text-ivory" href={item.href}>
              {item.label}
            </a>
          ))
        }
        <a
          href={hero.primaryCtaHref}
          target="_blank"
          rel="noreferrer"
          class="mt-2 inline-flex items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-semibold text-noir"
        >
          {hero.primaryCtaLabel}
        </a>
      </nav>
    </div>
  </header>

  <main class="bg-noir text-ivory">
    <section id="inicio" class="relative isolate flex min-h-svh items-end overflow-hidden pt-28">
      <img
        src={hero.backgroundImage}
        alt="Interior de barbería premium con barbero en acción"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(193,18,31,0.2),transparent_28%),linear-gradient(90deg,rgba(11,11,11,0.92)_0%,rgba(11,11,11,0.8)_42%,rgba(11,11,11,0.34)_100%)]"></div>
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-noir to-transparent"></div>

      <div class="relative mx-auto grid min-h-[92svh] w-full max-w-7xl items-end px-5 pb-14 md:px-8 md:pb-20 lg:grid-cols-[minmax(0,34rem)_1fr]">
        <div class="max-w-2xl" data-reveal>
          <p class="section-label">{hero.eyebrow}</p>
          <p class="mt-6 font-display text-4xl font-semibold uppercase tracking-[0.2em] text-accent sm:text-5xl">
            {brand.name}
          </p>
          <h1 class="mt-4 max-w-xl text-balance font-display text-5xl leading-[0.95] font-semibold text-ivory sm:text-6xl lg:text-7xl">
            {hero.headline}
          </h1>
          <p class="mt-6 max-w-lg text-base leading-7 text-ivory/76 sm:text-lg">
            {hero.subcopy}
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href={hero.primaryCtaHref}
              target="_blank"
              rel="noreferrer"
              class="inline-flex min-h-13 items-center justify-center rounded-full bg-accent px-6 py-4 text-sm font-semibold text-noir transition duration-300 hover:-translate-y-0.5 hover:bg-white"
            >
              {hero.primaryCtaLabel}
            </a>
            <a
              href={hero.secondaryCtaHref}
              class="inline-flex min-h-13 items-center justify-center rounded-full border border-white/20 px-6 py-4 text-sm font-semibold text-ivory transition duration-300 hover:border-accent/65 hover:text-accent"
            >
              {hero.secondaryCtaLabel}
            </a>
          </div>

          <div class="mt-8 flex flex-wrap gap-3 text-sm text-ivory/74">
            {
              hero.trustBadges.map((badge) => (
                <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 backdrop-blur-sm">
                  <span class="size-2 rounded-full bg-accent"></span>
                  {badge}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-white/8 bg-surface/60">
      <div class="mx-auto grid max-w-7xl gap-8 px-5 py-7 md:grid-cols-3 md:px-8">
        {
          usp.map((item) => (
            <div data-reveal class="flex items-start gap-4">
              <span class="mt-2 size-2 shrink-0 rounded-full bg-accent"></span>
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.28em] text-ivory">{item.title}</p>
                <p class="mt-2 text-sm leading-6 text-ivory/68">{item.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section id="nosotros" class="mx-auto grid max-w-7xl gap-14 px-5 py-24 md:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div data-reveal>
        <p class="section-label">Nosotros</p>
        <h2 class="mt-6 max-w-md font-display text-4xl leading-tight font-semibold text-ivory sm:text-5xl">
          Una barbería que se siente seria desde que entras y se nota más cuando sales.
        </h2>
      </div>
      <div data-reveal class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <p class="max-w-2xl text-lg leading-8 text-ivory/72">
          D’Barbers no está construida para verse correcta. Está construida para proyectar nivel. Cada servicio se trabaja con precisión, calma y criterio visual para que tu imagen no se vea improvisada, sino resuelta.
        </p>
        <div class="flex items-end gap-4 text-right">
          <div>
            <p class="text-4xl font-semibold text-accent">10+</p>
            <p class="mt-2 text-sm uppercase tracking-[0.25em] text-ivory/55">años refinando estilo</p>
          </div>
        </div>
      </div>
    </section>

    <section id="servicios" class="mx-auto max-w-7xl px-5 py-24 md:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div data-reveal>
          <p class="section-label">Servicios</p>
          <h2 class="mt-6 max-w-2xl font-display text-4xl leading-tight font-semibold text-ivory sm:text-5xl">
            Servicios diseñados para elevar tu imagen, no solo para salir del paso.
          </h2>
        </div>
        <p data-reveal class="max-w-xl text-base leading-7 text-ivory/68">
          Tres servicios clave, ejecutados con carácter y criterio. Lo suficiente para resolver tu estilo con una experiencia más limpia, más cómoda y mucho mejor terminada.
        </p>
      </div>

      <div class="mt-14 border-t border-white/10">
        {
          services.map((service, index) => (
            <article
              data-reveal
              class:list={[
                'grid gap-8 border-b border-white/10 py-10 md:grid-cols-[1.2fr_0.7fr_0.9fr]',
                service.featured && 'bg-gradient-to-r from-white/[0.03] to-transparent px-5 -mx-5 rounded-3xl md:px-8 md:-mx-8',
              ]}
            >
              <div>
                <p class="text-sm uppercase tracking-[0.28em] text-accent">0{index + 1}</p>
                <h3 class="mt-3 font-display text-3xl font-semibold text-ivory">{service.name}</h3>
                <p class="mt-4 max-w-xl text-base leading-7 text-ivory/68">{service.description}</p>
              </div>
              <div class="space-y-4 text-sm text-ivory/66">
                <div>
                  <p class="text-xs uppercase tracking-[0.24em] text-ivory/46">Duración</p>
                  <p class="mt-2 text-base text-ivory">{service.duration}</p>
                </div>
                <div>
                  <p class="text-xs uppercase tracking-[0.24em] text-ivory/46">Valor</p>
                  <p class="mt-2 text-base text-ivory">{service.priceLabel}</p>
                </div>
              </div>
              <div class="flex items-center md:justify-end">
                <a
                  href={service.ctaHref}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex min-h-12 items-center justify-center rounded-full border border-accent/60 px-5 py-3 text-sm font-semibold text-accent transition hover:-translate-y-0.5 hover:bg-accent hover:text-noir"
                >
                  {service.ctaLabel}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="destacado" class="mx-auto max-w-7xl px-5 py-24 md:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div data-reveal>
          <p class="section-label">Destacado</p>
          <h2 class="mt-6 max-w-lg font-display text-4xl leading-tight font-semibold text-ivory sm:text-5xl">
            Prueba visual para que no tengas que adivinar si el trabajo sí está a la altura.
          </h2>
          <p class="mt-6 max-w-xl text-base leading-7 text-ivory/68">
            Cortes limpios, barba definida y resultados que se ven bien tanto de cerca como en la calle. Esta sección existe para resolver la objeción más importante: si el nivel de ejecución realmente se nota.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          {
            gallery
              .filter((item) => item.type === 'result')
              .map((item) => (
                <figure data-reveal class="group overflow-hidden rounded-[2rem] border border-white/10 bg-surface">
                  <img
                    src={item.image}
                    alt={item.alt}
                    loading="lazy"
                    class="h-[28rem] w-full object-cover transition duration-700 group-hover:scale-[1.03]"
                  />
                  <figcaption class="border-t border-white/8 px-5 py-4 text-sm leading-6 text-ivory/68">
                    {item.caption}
                  </figcaption>
                </figure>
              ))
          }
        </div>
      </div>

      {
        gallery
          .filter((item) => item.type === 'before_after')
          .map((item) => (
            <figure data-reveal class="mt-6 overflow-hidden rounded-[2rem] border border-white/10 bg-surface">
              <div class="grid gap-px bg-white/10 md:grid-cols-2">
                <div class="relative bg-noir">
                  <img src={item.beforeImage} alt="Antes del servicio" loading="lazy" class="h-72 w-full object-cover md:h-96" />
                  <span class="absolute left-4 top-4 rounded-full bg-noir/72 px-3 py-2 text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-ivory">
                    Antes
                  </span>
                </div>
                <div class="relative bg-noir">
                  <img src={item.afterImage} alt="Después del servicio" loading="lazy" class="h-72 w-full object-cover md:h-96" />
                  <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-2 text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-noir">
                    Después
                  </span>
                </div>
              </div>
              <figcaption class="px-5 py-5 text-sm leading-6 text-ivory/68">{item.caption}</figcaption>
            </figure>
          ))
      }
    </section>

    <section class="mx-auto max-w-7xl px-5 py-24 md:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div data-reveal>
          <p class="section-label">Testimonios</p>
          <h2 class="mt-6 max-w-2xl font-display text-4xl leading-tight font-semibold text-ivory sm:text-5xl">
            Confianza que se construye con resultados, detalle y clientes que vuelven.
          </h2>
        </div>
        <p data-reveal class="max-w-xl text-base leading-7 text-ivory/68">
          La mejor forma de vender una barbería seria no es prometer de más, sino dejar que hablen la experiencia y el resultado final.
        </p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {
          testimonials.map((testimonial) => (
            <article data-reveal class="flex h-full flex-col rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
              <div class="flex gap-1 text-accent">
                {Array.from({ length: testimonial.rating }).map(() => <span>★</span>)}
              </div>
              <p class="mt-5 text-base leading-7 text-ivory/74">“{testimonial.quote}”</p>
              <div class="mt-auto pt-8">
                <p class="text-sm font-semibold uppercase tracking-[0.22em] text-ivory">{testimonial.name}</p>
                <p class="mt-2 text-sm text-ivory/56">{testimonial.service}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-5 pb-10 md:px-8">
      <div data-reveal class="overflow-hidden rounded-[2.25rem] border border-accent/25 bg-[linear-gradient(135deg,rgba(193,18,31,0.2),rgba(255,255,255,0.04))] px-6 py-12 md:px-10 lg:px-14">
        <p class="section-label !text-ivory/72">Reserva</p>
        <div class="mt-6 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div>
            <h2 class="max-w-3xl font-display text-4xl leading-tight font-semibold text-ivory sm:text-5xl">
              {closingCta.headline}
            </h2>
            <p class="mt-5 max-w-2xl text-base leading-7 text-ivory/74">{closingCta.body}</p>
          </div>
          <div class="flex flex-col gap-4 lg:items-end">
            <a
              href={closingCta.primaryCtaHref}
              target="_blank"
              rel="noreferrer"
              class="inline-flex min-h-13 w-full items-center justify-center rounded-full bg-white px-6 py-4 text-sm font-semibold text-noir transition hover:-translate-y-0.5 hover:bg-white lg:w-auto"
            >
              {closingCta.primaryCtaLabel}
            </a>
            <a
              href={closingCta.secondaryCtaHref}
              class="inline-flex min-h-13 w-full items-center justify-center rounded-full border border-white/18 px-6 py-4 text-sm font-semibold text-ivory transition hover:border-white/70 hover:text-white lg:w-auto"
            >
              {closingCta.secondaryCtaLabel}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="contacto" class="border-t border-white/8 bg-surface/55">
      <div class="mx-auto grid max-w-7xl gap-10 px-5 py-18 md:px-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div data-reveal>
          <p class="section-label">Contacto</p>
          <h2 class="mt-6 max-w-lg font-display text-4xl leading-tight font-semibold text-ivory sm:text-5xl">
            Agenda fácil, responde rápido y mantén tu imagen al nivel que quieres proyectar.
          </h2>
          <p class="mt-6 max-w-xl text-base leading-7 text-ivory/68">{contact.address}</p>
        </div>

        <div class="grid gap-10 md:grid-cols-2">
          <div data-reveal class="space-y-6">
            <div>
              <p class="text-xs uppercase tracking-[0.24em] text-ivory/45">{contact.whatsappLabel}</p>
              <a href={contact.whatsappHref} target="_blank" rel="noreferrer" class="mt-2 block text-lg text-ivory transition hover:text-accent">
                {contact.whatsappValue}
              </a>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.24em] text-ivory/45">{contact.phoneLabel}</p>
              <a href={contact.phoneHref} class="mt-2 block text-lg text-ivory transition hover:text-accent">
                {contact.phoneValue}
              </a>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.24em] text-ivory/45">{contact.emailLabel}</p>
              <a href={contact.emailHref} class="mt-2 block text-lg text-ivory transition hover:text-accent">
                {contact.emailValue}
              </a>
            </div>
          </div>

          <div data-reveal class="space-y-6">
            <div>
              <p class="text-xs uppercase tracking-[0.24em] text-ivory/45">Horario</p>
              <div class="mt-2 space-y-2 text-base text-ivory/72">
                {contact.hours.map((slot) => <p>{slot}</p>)}
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.24em] text-ivory/45">Síguenos</p>
              <div class="mt-2 flex flex-wrap gap-4 text-base text-ivory/72">
                {socialLinks.map((link) => <a href={link.href} target="_blank" rel="noreferrer" class="transition hover:text-accent">{link.label}</a>)}
              </div>
            </div>
          </div>
        </div>

        <div data-reveal class="lg:col-span-2">
          <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-noir/70">
            <div class="flex flex-col gap-4 border-b border-white/10 px-5 py-5 md:flex-row md:items-center md:justify-between">
              <div>
                <p class="text-xs uppercase tracking-[0.24em] text-ivory/45">Ubicación</p>
                <p class="mt-2 text-base text-ivory/76">
                  Explora la zona de atención en Google Maps y abre la ruta directa cuando vayas a reservar.
                </p>
              </div>
              <a
                href={contact.directionsHref}
                target="_blank"
                rel="noreferrer"
                class="inline-flex min-h-12 items-center justify-center rounded-full border border-accent/60 px-5 py-3 text-sm font-semibold text-accent transition hover:bg-accent hover:text-noir"
              >
                Abrir en Google Maps
              </a>
            </div>

            <iframe
              title={contact.mapTitle}
              src={contact.mapEmbedUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="h-[24rem] w-full border-0 md:h-[30rem]"
            ></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>

  <a
    href={contact.whatsappHref}
    target="_blank"
    rel="noreferrer"
    class="fixed bottom-4 right-4 z-50 inline-flex items-center gap-3 rounded-full bg-accent px-4 py-3 text-sm font-semibold text-noir shadow-[0_18px_50px_rgba(0,0,0,0.35)] transition hover:-translate-y-0.5 hover:bg-white sm:bottom-6 sm:right-6"
  >
    <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M7.5 7.5h9v9h-9z" opacity="0" />
      <path d="M7.75 6.75A6.75 6.75 0 1 1 5.08 18.7L3.75 20.25l.52-2.13A6.75 6.75 0 0 1 7.75 6.75Z" stroke-linejoin="round" />
      <path d="M9.8 10.2c.14-.3.25-.32.46-.33h.4c.13 0 .31.05.4.27.1.22.33.8.37.87.03.07.05.17 0 .27-.05.1-.08.17-.16.26-.08.09-.17.2-.24.27-.08.08-.17.17-.07.34.1.18.46.76.98 1.22.67.6 1.22.79 1.4.88.18.08.28.07.39-.04.1-.1.44-.51.55-.69.12-.17.24-.14.4-.08.17.06 1.06.5 1.24.6.18.08.3.12.34.2.04.09.04.5-.12.98-.16.48-.9.92-1.25.96-.32.04-.73.06-1.18-.1-.27-.1-.62-.21-1.07-.4a6 6 0 0 1-2.1-1.3 7 7 0 0 1-1.46-1.93c-.15-.27-.4-.73-.4-1.23 0-.5.26-.74.35-.84.1-.1.22-.14.29-.14Z" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span>WhatsApp</span>
  </a>

  <script is:inline>
    const header = document.querySelector('[data-site-header]');
    const menuToggle = document.querySelector('[data-menu-toggle]');
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    const mobileLinks = mobileMenu?.querySelectorAll('a');

    const syncHeader = () => {
      if (!header) return;
      header.dataset.scrolled = window.scrollY > 24 ? 'true' : 'false';
    };

    syncHeader();
    window.addEventListener('scroll', syncHeader, { passive: true });

    menuToggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('hidden') === false;
      menuToggle.setAttribute('aria-expanded', String(isOpen));
    });

    mobileLinks?.forEach((link) =>
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        menuToggle?.setAttribute('aria-expanded', 'false');
      }),
    );

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );

    document.querySelectorAll('[data-reveal]').forEach((element) => observer.observe(element));
  </script>
</MainLayout>
